<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Fondo de escritorio personalizable -->
    <ImageView
        android:id="@+id/desktopWallpaper"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:background="@color/desktop_fallback_bg"
        android:contentDescription="@null" />

    <!-- Grid de iconos anclados en el escritorio -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/desktopGrid"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="56dp"
        android:paddingTop="24dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:clipToPadding="false" />

    <!-- Barra de tareas centrada, estilo Windows 11 -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/taskbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:background="@color/taskbar_bg"
        android:elevation="8dp">

        <!-- Grupo centrado: boton inicio + apps abiertas -->
        <LinearLayout
            android:id="@+id/centerGroup"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageButton
                android:id="@+id/btnStart"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_start"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/start_menu" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/runningAppsBar"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginStart="4dp"
                android:clipToPadding="false" />

        </LinearLayout>

        <!-- Bandeja de sistema: siempre pegada a la derecha -->
        <LinearLayout
            android:id="@+id/systemTray"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingEnd="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageButton
                android:id="@+id/btnVolume"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:src="@drawable/ic_volume"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@null" />

            <ImageView
                android:id="@+id/wifiIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="10dp"
                android:src="@drawable/ic_wifi_on"
                android:contentDescription="@null" />

            <ImageView
                android:id="@+id/batteryIcon"
                android:layout_width="22dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_battery"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/batteryText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="12dp"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:text="100%" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end"
                android:background="?attr/selectableItemBackground"
                android:id="@+id/clockArea">

                <TextView
                    android:id="@+id/clockText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:text="00:00" />

                <TextView
                    android:id="@+id/dateText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#CCCCCC"
                    android:textSize="10sp"
                    android:text="01/01/2026" />
            </LinearLayout>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Panel de volumen (oculto por defecto) -->
    <LinearLayout
        android:id="@+id/volumePanel"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="60dp"
        android:layout_marginEnd="8dp"
        android:orientation="vertical"
        android:background="@color/start_menu_bg"
        android:elevation="12dp"
        android:visibility="gone"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Volumen"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <SeekBar
            android:id="@+id/volumeSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- Menu Inicio (oculto por defecto) -->
    <LinearLayout
        android:id="@+id/startMenu"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="bottom|start"
        android:orientation="vertical"
        android:background="@color/start_menu_bg"
        android:elevation="12dp"
        android:visibility="gone"
        android:padding="12dp">

        <EditText
            android:id="@+id/searchBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/search_apps"
            android:textColorHint="#AAAAAA"
            android:textColor="#FFFFFF"
            android:background="#331F1F1F"
            android:padding="10dp"
            android:layout_marginBottom="8dp"
            android:inputType="text" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/allAppsList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnChangeWallpaper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/change_wallpaper"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnResolution"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cambiar resolucion (Shizuku)"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnActivateShizuku"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Activar Shizuku"
            android:layout_marginTop="8dp" />
    </LinearLayout>

</FrameLayout>
